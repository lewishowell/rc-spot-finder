# Vercel Postgres - These are automatically set when you add Vercel Postgres to your project
POSTGRES_PRISMA_URL="postgresql://..."
POSTGRES_URL_NON_POOLING="postgresql://..."

# NextAuth.js
NEXTAUTH_SECRET=<run: openssl rand -base64 32>
NEXTAUTH_URL=http://localhost:3000

# Google OAuth - Get from Google Cloud Console
# https://console.cloud.google.com > APIs & Services > Credentials > Create OAuth Client ID
# Add http://localhost:3000/api/auth/callback/google to Authorized redirect URIs
GOOGLE_CLIENT_ID="<your-google-client-id>"
GOOGLE_CLIENT_SECRET="<your-google-client-secret>"

# Instagram Login - Get from Meta Developer Portal
# https://developers.facebook.com > My Apps > Create App > Add "Instagram" product
# Requires a professional (Business/Creator) Instagram account (free to switch)
# Add http://localhost:3000/api/auth/callback/instagram to Valid OAuth Redirect URIs
# Scopes: instagram_business_basic, instagram_business_content_publish
INSTAGRAM_CLIENT_ID="<your-instagram-app-id>"
INSTAGRAM_CLIENT_SECRET="<your-instagram-app-secret>"

# Cloudinary - Get from https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME="<your-cloud-name>"
CLOUDINARY_API_KEY="<your-api-key>"
CLOUDINARY_API_SECRET="<your-api-secret>"
